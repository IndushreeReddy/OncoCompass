# Copy to .env and set values

# Runtime directories (relative to project root or absolute)
UPLOAD_DIR=uploads
RESULTS_DIR=results
REPORTS_DIR=reports

# VEP script path (relative to project root or absolute)
VEP_SCRIPT_PATH=scripts/run_vep.sh

# Data directory: VEP cache, knowledge base (relative to project root or absolute)
DATA_DIR=data
KNOWLEDGE_BASE_PATH=data/knowledge_base
# Optional: IntOGen driver genes TSV, e.g. IntOGen-DriverGenes_LUAD.tsv (column Symbol)
DRIVER_GENES_PATH=data/IntOGen-DriverGenes_LUAD.tsv
